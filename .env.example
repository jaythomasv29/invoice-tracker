# Copy this file to .env and fill in real values. Never commit .env.
#
# Both keys below are safe to ship in the client bundle (Clerk's "publishable"
# key and Supabase's "anon" key are designed for this) — that's why they use
# the EXPO_PUBLIC_ prefix, which Expo inlines into the built app. Never put a
# Clerk *secret* key or a Supabase *service_role* key behind EXPO_PUBLIC_ —
# those belong server-side only (Supabase Edge Functions), never in the app.

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Enables crash/error reporting via Sentry — leave blank to disable
# (the SDK no-ops gracefully with no DSN). Get one from sentry.io.
EXPO_PUBLIC_SENTRY_DSN=

# Required before App Store submission. Host the two files in /legal
# (e.g. GitHub Pages) and put their public URLs here. Leave blank during
# development — the app falls back to a toast instead of a dead link.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=
